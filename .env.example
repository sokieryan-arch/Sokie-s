# DeepSeek server-side key. Do not use NEXT_PUBLIC_ for this value.
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# Supabase project settings for the server-side character library.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional fallback when service role is not available for local experiments.
